{
  "name": "@desert-ant-labs/shapes",
  "version": "0.5.0",
  "description": "On-device single-stroke shape recognition for JavaScript. Runs in the browser (WebAssembly + LiteRT.js) and server-side in Node (native), from one import.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/Desert-Ant-Labs/shapes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Desert-Ant-Labs/shapes.git",
    "directory": "packages/shapes-node"
  },
  "keywords": [
    "shape-recognition",
    "handwriting",
    "stroke",
    "on-device",
    "geometry",
    "wasm",
    "litert",
    "isomorphic"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./node.js",
  "browser": "./browser.js",
  "types": "./index.d.ts",
  "scripts": {
    "test": "node --test test/shapes.test.mjs"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": "./browser.js",
      "node": "./node.js",
      "default": "./browser.js"
    },
    "./wasm": "./dist/ShapesWeb.wasm"
  },
  "files": [
    "browser.js",
    "node.js",
    "index.d.ts",
    "dist",
    "model",
    "native",
    "LICENSE.md"
  ],
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.3.0",
    "koffi": "^2.9.0"
  },
  "peerDependencies": {
    "@litertjs/core": ">=2.1.0"
  },
  "peerDependenciesMeta": {
    "@litertjs/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@litertjs/core": "^2.5.2"
  }
}
